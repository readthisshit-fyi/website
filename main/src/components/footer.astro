---
import MouseSvg from "../assets/mouse.svg";
---

<MouseSvg class="mouseSvg" />
<div class="footer">
  <div class="footerContainer"></div>
</div>

<style lang="scss">
  .mouseSvg {
    position: relative;
    bottom: -40px;
    left: 2%;
  }

  .footer {
    width: 100%;
    height: 300px;
    border-top: 3px solid var(--text);

    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: end;

    .footerContainer {
      height: 100%;
      width: 100%;
      max-width: var(--max-width);
    }
  }
</style>
