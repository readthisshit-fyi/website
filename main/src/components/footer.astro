---
import MouseSvg from "../assets/mouse.svg";
import { m } from "../paraglide/messages";
---

<MouseSvg class="mouseSvg" />
<div class="footer">
  <div class="footerContainer">
    <section>
      <p>{m.legal_stuff()}</p>
      <a href="/legal/terms">{m.terms_of_service()}</a>
      <a href="/legal/privacy">{m.privacy_policy()}</a>
      <a href="/legal/cookies">{m.cookies()}</a>
      <a href="/legal/rules">{m.rules()}</a>
    </section>
  </div>
</div>

<style lang="scss">
  .mouseSvg {
    position: relative;
    bottom: -40px;
    left: 2%;
  }

  .footer {
    width: 100%;
    height: auto;
    border-top: 3px solid var(--text);

    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: end;

    padding: 40px 0;

    .footerContainer {
      height: 100%;
      width: 100%;
      max-width: var(--max-width);
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 24px;

      section {
        display: flex;
        flex-direction: column;
        gap: 4px;

        p {
          border-bottom: 2px solid var(--text);
          font-size: 24px;
          font-weight: 600;
          margin-bottom: 12px;
        }

        a {
          border-bottom: 2px solid transparent;
          transition: 0.05s ease all;

          &:hover {
            border-bottom: 2px solid var(--text);
            transition: 0.05s ease all;
          }
        }
      }
    }
  }
</style>
