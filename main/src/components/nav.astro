---
import SvgLogo from '../assets/logo-alpha.svg';
import '../style/colors.css';

import MoonIcon from '../assets/icons/moon.svg';
import SunIcon from '../assets/icons/sun.svg';
---

<nav>
	<div class="navContainer">
		<SvgLogo class="logo" />
		<ul class="navLinks">
			<li><a href="" class="navLink">Homepage</a></li>
			<li><a href="" class="navLink">Featured</a></li>
			<li><a href="" class="navLink">All Articles</a></li>
			<li><a href="" class="navLink">Contributte</a></li>
		</ul>
		<div class="buttonAndAccountContainer">
			<button class="themeSwitcher" id="themeButton">
				<MoonIcon class="moon"/>
				<SunIcon class="sun" />
			</button>
			<script>
				const themeButton = document.getElementById("themeButton");

				themeButton?.addEventListener('click', (e) => {
					const current = document.documentElement.getAttribute('data-theme');
					const next = current === 'dark' ? 'light' : 'dark';

					document.documentElement.setAttribute('data-theme', next);
					localStorage.setItem('theme', next);
				})
			</script>
		</div>
	</div>
</nav>

<style lang="scss">
	:global([data-theme="dark"]) .sun {
		display: none;
	}

	:global([data-theme="light"]) .moon {
		display: none;
	}

  nav {
    transition: background-color 0.1s ease, border-color 0.1s ease;
    border-bottom: 3px solid var(--text);
    background: var(--background);
    width: 100%;
    height: 60px;
    display: flex;
    justify-content: center;
    box-sizing: border-box;
    overflow: visible;

    .navContainer {
      box-sizing: border-box;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      height: 100%;
      max-width: var(--max-width);
      width: 100%;
      padding: 12px 40px;
      gap: 40px;
      overflow: visible;

      .navLinks {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: center;
        gap: 40px;
        flex: 1;
        list-style: none;
        padding: 0;
        margin: 0;

        .navLink {
          font-size: 20px;
          font-weight: 500;
          color: inherit;
          text-decoration: none;
          border-bottom: 0 solid var(--text);
          transition: border-bottom 0.05s ease-in-out;

          &:hover {
            border-bottom: 2px solid var(--text);
          }

          &:active {
            color: var(--text);
          }
        }
      }

      .logo {
        height: auto;
        width: auto;
        flex-shrink: 0;
        align-self: end;
        justify-self: start;
        overflow: hidden;
        display: block;
      }

      .buttonAndAccountContainer {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 10px;
        align-self: stretch;
        justify-self: end;

        .themeSwitcher {
          background: none;
          display: flex;
          width: 36px;
          height: 36px;
          padding: 5px;
          justify-content: center;
          align-items: center;
          border-radius: 7px;
          border: 2px solid var(--text);
          aspect-ratio: 1/1;
          flex-shrink: 0;
          svg {
            aspect-ratio: 1/1;
          }
        }
      }
    }
  }
</style>
