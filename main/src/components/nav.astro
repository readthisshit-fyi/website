---
import SvgLogo from '../assets/logo-alpha.svg';
import '../style/colors.css';

import MoonIcon from '../assets/icons/moon.svg';
import SunIcon from '../assets/icons/sun.svg';
---

<nav>
	<div class="navContainer">
		<SvgLogo class="logo" />
		<ul class="navLinks">
			<li><a href="" class="navLink">Homepage</a></li>
			<li><a href="" class="navLink">Featured</a></li>
			<li><a href="" class="navLink">All Articles</a></li>
			<li><a href="" class="navLink">Contributte</a></li>
		</ul>
		<div class="buttonAndAccountContainer">
			<button class="themeSwitcher" id="themeButton">
				<MoonIcon class="moon"/>
				<SunIcon class="sun" />
			</button>
			<script>
				const themeButton = document.getElementById("themeButton");

				themeButton?.addEventListener('click', (e) => {
					const current = document.documentElement.getAttribute('data-theme');
					const next = current === 'dark' ? 'light' : 'dark';

					document.documentElement.setAttribute('data-theme', next);
					localStorage.setItem('theme', next);
				})
			</script>
		</div>
	</div>
</nav>

<style>
	:global([data-theme="dark"]) .sun {
		display: none;
	}

	:global([data-theme="light"]) .moon {
		display: none;
	}

	nav {
		transition: background-color 0.1s ease, border-color 0.1s ease;
		border-bottom: 3px solid var(--text);
		background: var(--background);
		width: 100%;
		display: flex;
		box-sizing: border-box;
		justify-content: center;
		height: 60px;
    overflow: visible;
	}

	.navContainer {
		box-sizing: border-box;
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		height: 100%;
		padding: 12px 40px;
		gap: 40px;
		max-width: 1400px;
		width: 100%;
		overflow: visible;
	}

	.navLinks {
		display: flex;
		flex-direction: row;
		justify-content: center;
		align-items: center;
		gap: 40px;
		list-style: none;
		flex: 1;
		padding: 0;
		margin: 0;
	}

	.navLink {
		font-size: 20px;
		font-weight: 500;
		text-decoration: none;
		color: inherit;
		border-bottom: 0px solid var(--text);
		transition: 
			border-bottom 0.05s ease-in-out;
	}

	.navLink:hover {
		border-bottom: 2px solid var(--text);
	}

	.navLink:active {
		color: var(--text);
	}

	.logo {
		height: auto;
		width: auto;
		flex-shrink: 0;
		align-self: end;
		justify-self: start;
		overflow: hidden;
		display: block;
	}

	.themeSwitcher{
		background: none;
		display: flex;
		width: 36px;
		height: 36px;
		padding: 5px;
		justify-content: center;
		align-items: center;
		gap: 10px;
		flex-shrink: 0;
		aspect-ratio: 1/1;

		border-radius: 7px;
		border: 2px solid var(--text);
	}

	.buttonAndAccountContainer {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		gap: 10px;
		align-self: stretch;
		justify-self: end;
	}
</style>
