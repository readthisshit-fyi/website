---
import MainLayout from "../layouts/main.astro";
---

<MainLayout>
  <section>
    <div class="numberLineText">
      <p class="number">404</p>
      <hr />
      <h1 class="text">Page not found</h1>
    </div>
  </section>
</MainLayout>

<style lang="scss">
  section {
    width: 100%;
    max-width: var(--max-content-width);
    display: flex;
    flex-direction: column;
    gap: 16px;

    padding: 100px 24px;

    .numberLineText {
      display: flex;
      flex-direction: row;
      gap: 24px;

      justify-content: center;
      align-items: center;

      .number,
      h1 {
        font-size: 48px;
        font-weight: 600;
        text-wrap-mode: nowrap;
      }

      hr {
        width: 100%;
        height: 4px;
        border: 0;
        background: var(--text);
        border-radius: 4px;
      }
    }
  }
</style>
