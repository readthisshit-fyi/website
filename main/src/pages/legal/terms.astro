<style lang="scss">
  .contentContainer {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .termsContent {
    width: 100%;
    max-width: var(--max-content-width);
    padding: 0 20px;

    .header {
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      height: auto;
      padding: 70px 0;

      h1 {
        color: var(--text);
        font-size: 48px;
        font-style: normal;
        font-weight: 600;
        line-height: normal;
        text-align: left;
        width: 100%;
        margin: 0 0 20px 0;
      }

      .lastUpdatedDate {
        text-align: left;
        width: 100%;
        font-size: 14px;
        color: var(--dimmed-text-two);
        padding: 0;
        margin: 0;
      }
    }

    .termsBody {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding-bottom: 100px;

      p {
        color: var(--text);
        font-size: 16px;
        line-height: 1.6;
        margin: 0;

        strong {
          font-weight: 600;
        }

        a {
          color: var(--text);
          text-decoration: underline;
          transition: opacity 0.2s ease;

          &:hover {
            opacity: 0.7;
          }
        }
      }

      h2 {
        color: var(--text);
        font-size: 24px;
        font-style: normal;
        font-weight: 600;
        line-height: normal;
        margin: 0;
        padding: 0 0 0 16px;
        border-left: 4px solid var(--text);
        opacity: 0.8;
      }

      ul {
        list-style: none;
        padding-left: 20px;
        margin: 0;

        li {
          color: var(--text);
          font-size: 16px;
          line-height: 1.6;
          margin-bottom: 10px;
          position: relative;
          padding-left: 15px;

          &::before {
            content: "•";
            position: absolute;
            left: 0;
            font-weight: bold;
          }
        }
      }
    }
  }

  @media (max-width: 768px) {
    .termsContent {
      .header {
        padding: 40px 0;

        h1 {
          font-size: 32px;
        }

        .lastUpdatedDate {
          font-size: 12px;
        }
      }

      .termsBody {
        gap: 16px;
        padding-bottom: 50px;

        p {
          font-size: 14px;
        }

        h2 {
          font-size: 20px;
        }

        ul li {
          font-size: 14px;
        }
      }
    }
  }
</style>
