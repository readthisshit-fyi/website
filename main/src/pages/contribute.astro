---
import MainLayout from "../layouts/main.astro";
---

<MainLayout class="contentContainer">
  <section class="titlesNStuff">
    <h1>Ways to contribute to the project</h1>
    <!-- <h2>
      This page is resetted weekly, so don't forget to click the fish icon under your favorite website when you visit it ;)<br />
      <br />You can vote daily on your favorite websites to boost them in this list!
    </h2> -->
  </section>
  <section>
    <div class="subtitlesNStuff">
      <h2>Suggest a website</h2>
      <p>Found something worth reading? Send it below and let our mods check it out</p>
    </div>
    <form action="/api/submitwebsite" method="post" class="websiteForm">
      <div class="inputField">
        <label for="websiteUrl">Website Url</label>
        <input type="text" name="websiteUrl" id="websiteUrl" placeholder="https://example.com" />
      </div>
      <div class="inputField">
        <label for="reason">What's your opinion on the website?</label>
        <textarea name="reason" rows="4" id="reason" placeholder="Well.. I think the website actually does a great job at..."></textarea>
      </div>
      <input type="submit" value="Submit" />
    </form>
  </section>
  <section>
    <div class="subtitlesNStuff">
      <h2>Help translate the project</h2>
      <p>The website is not in your language yet? Fix that on Crowdin! Future readers will thank you</p>
    </div>
    <div>
      <a href="https://crowdin.com">Open crowdin</a>
    </div>
  </section>
  <section>
    <div class="subtitlesNStuff">
      <h2>Contribute to code</h2>
      <p>Know Astro, Postgres, or Vue? The repo's open, the cat doesn't judge your commit history :^</p>
    </div>
    <div></div>
  </section>
</MainLayout>

<style lang="scss">
  .contentContainer {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  section {
    display: flex;
    align-items: start;
    justify-content: start;
    width: var(--max-content-width);
    height: auto;
    align-self: center;
    flex-direction: column;
    padding: 25px 0;
    gap: 16px;

    .subtitlesNStuff {
      gap: 5px;
      display: flex;
      flex-direction: column;
    }

    .websiteForm {
      display: flex;
      flex-direction: column;
      gap: 16px;
      width: 50%;

      .inputField {
        display: flex;
        flex-direction: column;

        input,
        textarea {
          width: 100%;
          display: flex;
          flex-direction: column;
          gap: 2px;
          background: var(--background);
          border: var(--text) 2px solid;
          padding: 6px;
          border-radius: 4px;
          color: var(--text);
          resize: none;
        }
      }

      [type="submit"] {
        width: auto;
        display: flex;
        flex-direction: column;
        align-self: flex-start;
        gap: 2px;
        font-weight: 600;
        font-size: 16px;
        background: var(--background);
        border: var(--text) 2px solid;
        padding: 6px 12px;
        border-radius: 4px;
        color: var(--text);
        transition: all 0.2s ease;

        &:hover {
          background: var(--text);
          color: var(--background);
          transition: all 0.1s ease;
        }
      }
    }
  }

  h1 {
    color: var(--text);
    font-size: 48px;
    font-style: normal;
    font-weight: 600;
    line-height: normal;
  }

  h2 {
    color: var(--text);
    font-size: 24px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
  }

  p {
    color: var(--dimmed-text);
  }

  .titlesNStuff {
    padding: 70px 0;
  }
</style>
